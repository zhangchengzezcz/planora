    "Switching curriculum deletes existing tasks for the current curriculum and resets subjects to the new curriculum defaults." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Switching curriculum deletes existing tasks for the current curriculum and resets subjects to the new curriculum defaults."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カリキュラムを切り替えると、現在のカリキュラムで作成済みのタスクが削除され、科目は新しいカリキュラムの既定値にリセットされます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "切换课程后会清空当前课程体系内已创建的任务，并将科目重置为新课程体系的默认必选项。"
          }
        }
      }
    },
    "System" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "System"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "システム"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "系统"
          }
        }
      }
    },
    "System font availability can vary by device and OS version. Changing the interface font may affect glyphs, line wrapping, and layout, and some text may be clipped or displayed unexpectedly. You can turn this off at any time to restore the system font." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "System font availability can vary by device and OS version. Changing the interface font may affect glyphs, line wrapping, and layout, and some text may be clipped or displayed unexpectedly. You can turn this off at any time to restore the system font."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "システムフォントの利用状況はデバイスやOSのバージョンによって異なります。画面全体のフォントを変更すると、字形、改行、レイアウトに影響し、一部のテキストが切れたり正しく表示されない場合があります。いつでも無効にしてシステムフォントへ戻せます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "系统字体在不同设备和系统版本中的可用性可能不同。更换界面字体可能影响字形、换行与布局，少数文本可能出现截断或显示异常。你可以随时关闭此功能恢复系统默认字体。"
          }
        }
      }
    },
    "System Fonts" : {
