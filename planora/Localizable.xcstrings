    "Changing curriculum resets subjects to the new curriculum defaults; existing tasks will not be kept." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Changing curriculum resets subjects to the new curriculum defaults; existing tasks will not be kept."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カリキュラムを変更すると、科目は新しい既定値にリセットされ、作成済みのタスクは保持されません。"
          }
